# Supabase (web: anon key only; api: service role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared JWT secret (web server + Worker must match)
JWT_SECRET=

# Cloudflare Worker (apps/api) — production OTP email via Resend
RESEND_API_KEY=
OTP_EMAIL_FROM=AIA-PAMA Election <onboarding@resend.dev>
TURNSTILE_SECRET_KEY=
OTP_PROVIDER_API_KEY=

# Web
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_ELECTION_PHASE=nomination

# ELECOM admin login (Worker reads from apps/api/.dev.vars — mirror JWT_SECRET here for web cookies)
# ELECOM_ADMIN_EMAIL=elecom@aiapama.test
# ELECOM_ADMIN_PASSWORD=change-me-elecom-dev
